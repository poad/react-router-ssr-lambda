{
  "name": "@react-router-ssr-lambda/app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "eslint:check": "eslint --cache --cache-location ./node_modules/.cache/eslint",
    "eslint:fix": "eslint --fix --cache --cache-location ./node_modules/.cache/eslint",
    "lint": "pnpm --parallel --filter '@react-router/app' run /^.+:check$/",
    "lint-fix": "pnpm run --filter '@react-router/app' /^.+:fix$/",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "isbot": "^5.1.40",
    "morgan": "^1.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^7.15.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12"
  }
}